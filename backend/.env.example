# Copy this file to .env and fill in your values
# Get Gemini API key free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.0-flash-exp

# MongoDB — run locally or use Atlas free tier
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sahaay_db

# AI processing config
ISSUE_SIMILARITY_THRESHOLD=0.85

# Gmail SMTP — optional, notifications only
# Use App Password: Google Account → Security → 2FA → App Passwords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# For admin email notifications
ADMIN_NOTIFICATION_EMAIL=your_email@gmail.com

# Google Custom Search — free 100 queries/day
# https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_engine_id

# Base URL for serving uploaded files
PUBLIC_UPLOAD_BASE_URL=http://localhost:8000
